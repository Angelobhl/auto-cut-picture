# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Storage path (optional, defaults to ./storage/)
STORAGE_PATH=./storage

# qwen3-vl-plus Configuration (阿里云百炼)
# DashScope API Key (从 https://bailian.console.aliyun.com/ 获取，格式: sk-xxxxxxx)
QWEN_API_KEY=your_dashscope_api_key_here

# Qwen API URL (可选，默认使用阿里云官方地址)
QWEN_API_URL=

# Qwen 模型名称 (可选，默认: qwen3-vl-plus)
QWEN_MODEL=qwen3-vl-plus
